local AutoSection = HomeTab:Section({ Title = "Auto Farm" })

-- Toggle: Auto Weight
AutoSection:Toggle({
    Title    = "Auto Weight",
    Default  = false,
    Callback = function(Value)
        autoWeightEnabled = Value
        if Value then
            startAutoTool("Weight", function() return autoWeightEnabled end)

            -- Re-run on respawn
            player.CharacterAdded:Connect(function()
                task.wait(1)
                if autoWeightEnabled then
                    startAutoTool("Weight", function() return autoWeightEnabled end)
                end
            end)
        end
        print("Auto Weight:", Value)
    end,
})

