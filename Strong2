-- ============================================
--          AUTO TOOL LOGIC (SHARED)
-- ============================================

local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- State toggles
local autoWeightEnabled  = false
local autoSitupsEnabled  = false
local autoBoxingEnabled  = false

-- Generic equip & loop function
local function startAutoTool(toolName, getEnabled)
    task.spawn(function()
        while getEnabled() do
            local character = player.Character
            if character then
                local backpack = player:FindFirstChild("Backpack")
                local tool = (backpack and backpack:FindFirstChild(toolName))
                           or character:FindFirstChild(toolName)

                if tool then
                    if tool.Parent ~= character then
                        tool.Parent = character
                    end
                    if getEnabled() then
                        tool:Activate()
                    end
                end
            end
            task.wait(0.1)
        end
    end)
end

